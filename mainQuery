DECLARE @clean VARCHAR(MAX) = @taglist;
SET @clean = REPLACE(@clean, CHAR(13), ',');  -- CR
SET @clean = REPLACE(@clean, CHAR(10), ',');  -- LF
SET @clean = REPLACE(@clean, CHAR(9),  ',');  -- TAB

DECLARE @list TABLE (tuple VARCHAR(64) PRIMARY KEY);

INSERT INTO @list(tuple)
SELECT DISTINCT LTRIM(RTRIM(value))
FROM STRING_SPLIT(@clean, ',')
WHERE LTRIM(RTRIM(value)) <> '';



SELECT
    TOP 100 
	q.TagCode, 
	q.OperatingDT, 
	q.GenMW, 
	q.TransMW,
	q.Interval,
	q.TransMW - q.GenMW AS Curtailment--, SUM(q.TransMW) AS SumTransMW, SUM(q.GenMW) AS FlowMW   --SUM(Curtailment) AS TotalCurtailment
FROM (
    SELECT
    hp.TagCode,
    hp.Interval,
    hp.OperatingDT,
    hp.MW  AS GenMW,
    SUM(ta.MW)  AS TransMW --To avoid the problem that occurs that gives new rows when trans is split between lines,
	
FROM Tagging_ETAG.dbo.TagHourProfileETAGView hp
LEFT JOIN Tagging_ETAG.dbo.TagHourTransmissionAllocationETAGView ta
    ON hp.TagCode     = ta.TagCode
   AND hp.Interval    = ta.Interval
   AND hp.OperatingDT = ta.OperatingDT
WHERE hp.TagCode IN (SELECT tuple FROM @list) AND hp.OperatingDT > '2025-01-01'
GROUP BY
    hp.TagCode,
    hp.Interval,
    hp.OperatingDT,
    hp.MW,
	ta.TransmissionServiceProvider_ETAGID, --Here is the current issue. We need to group by TSP with a unique PSE, then sum all the AREFs' TransMW
	ta.PurchasingSellingEntity_ETAGID
) AS q
--GROUP BY q.TagCode, q.OperatingDT
---HAVING SUM(q.Curtailment) <> 0
ORDER BY q.TagCode,
q.OperatingDT;
